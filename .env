GROQ_API_KEY=your-groq-api-key-here
MODEL=llama-3.1-70b-versatile
LOG_LEVEL=INFO
AGENT_TIMEOUT=30
ENVIRONMENT=production
PYTHONUNBUFFERED=1
PORT=8000

# ============================================
# Cognee Memory Configuration
# ============================================
# Enable/Disable Cognee memory layer
COGNEE_ENABLED=true

# Cognee dataset name
COGNEE_DATASET=promptly_agent

# LLM Configuration for Cognee
# For Cognee embeddings and memory operations
# Options: openai, anthropic, groq, ollama, etc.
LLM_API_KEY=your-openai-api-key-or-groq-key
LLM_PROVIDER=openai

# Database Configuration
# Options: postgres, sqlite
DB_PROVIDER=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=cognee
DB_PASSWORD=cognee
DB_NAME=cognee_db

# Vector Database
# Options: pgvector, weaviate, milvus
VECTOR_DB_PROVIDER=pgvector

# Graph Database
# Options: postgres, neo4j, kuzu
GRAPH_DATABASE_PROVIDER=postgres

# Cache Backend
# Options: postgres, redis
CACHE_BACKEND=postgres

# Data Storage
DATA_ROOT_DIRECTORY=.cognee_data

# Feature Flags
ENABLE_MEMORY_CONTEXT=true
ENABLE_AGENT_LEARNING=true
MEMORY_CONTEXT_LIMIT=500
